          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Primeiro Mistério Glorioso"
          }
        }
      }
    },
    "mysteries.glorious.fourth.name" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Assumption"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maria è assunta in cielo"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assunção de Maria"
          }
        }
      }
    },
    "mysteries.glorious.fourth.scripture" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Henceforth all generations will call me blessed; for he who is mighty has done great things for me\" (Lk 1:48-49)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allora Maria disse: «L'anima mia magnifica il Signore e il mio spirito esulta in Dio, mio salvatore, perché ha guardato l'umiltà della sua serva. D'ora in poi tutte le generazioni mi chiameranno beata. Grandi cose ha fatto per me l'Onnipotente e Santo è il suo nome; di generazione in generazione la sua misericordia per quelli che lo temono». (Lc 1,46-50)"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Por isto, desde agora, me proclamarão bem-aventurada todas as gerações, porque realizou em mim maravilhas aquele que é poderoso e cujo nome é Santo» (Lc 1, 48-49). "
          }
        }
      }
    },
    "mysteries.glorious.fourth.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
