            "value" : "Em nome do Pai, do Filho e do Espírito Santo. "
          }
        }
      }
    },
    "rosary.introduction.scripture" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"O God come to my aid; O Lord, make haste to help me\" (Psalm 69/70)"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«O Dio vieni a salvarmi. Signore, vieni presto in mio aiuto» (Salmo 69/70)"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Ó Deus, vinde em nosso auxílio; Senhor, socorrei-nos e salvai-nos» (Salmo 69/70)"
          }
        }
      }
    },
