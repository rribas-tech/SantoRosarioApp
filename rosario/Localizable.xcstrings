    "prayers.aveMaria.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hail, Mary, full of grace, the Lord is with thee: blessed art thou among women, and blessed is the fruit of thy womb, Jesus. Holy Mary, Mother of God, pray for us sinners, now, and at the hour of our death. Amen."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ave o Maria, piena di grazia, il Signore è con te. Tu sei benedetta fra le donne e benedetto è il frutto del seno tuo, Gesù. Santa Maria, Madre di Dio, prega per noi peccatori, adesso e nell'ora della nostra morte. Amen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ave Maria,  cheia de graça, o Senhor é convosco. Bendita sois Vós entre as mulheres, bendito é o fruto de Vosso ventre, Jesus. Santa Maria, Mãe de Deus, rogai por nós, pecadores, agora e na hora de nossa morte. Amém."
          }
        }
      }
    },
    "prayers.aveMaria.name" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hail Mary"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ave Maria"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ave Maria"
          }
        }
      }
    },
    "prayers.credo.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "sem tradução"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "sem tradução"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Creio em Deus, Pai todo-poderoso, Criador do Céu e da Terra\n\nE em Jesus Cristo, seu único Filho, nosso Senhor\nque foi concebido pelo poder do Espírito Santo;\nnasceu da Virgem Maria;\npadeceu sob Pôncio Pilatos,\nfoi crucificado, morto e sepultado;\ndesceu à mansão dos mortos;\nressuscitou ao terceiro dia;\nsubiu aos Céus;\nestá sentado à direita de Deus Pai todo-poderoso,\nde onde há-de vir a julgar os vivos e os mortos.\n\nCreio no Espírito Santo;\nna santa Igreja Católica;\nna comunhão dos Santos;\nna remissão dos pecados;\nna ressurreição da carne;\ne na vida eterna. Amém."
          }
        }
      }
    },
    "prayers.credo.name" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "sem tradução"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "sem tradução"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Credo (Símbolo dos Apóstolos)"
          }
        }
      }
    },
    "prayers.gloriaPatri.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Glory be to the Father, and to the Son, and to the Holy Spirit. As it was in the beginning, is now, and ever shall be, world without end. Amen."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gloria al Padre e al Figlio e allo Spirito Santo. Come era nel principio e ora e sempre, nei secoli dei secoli. Amen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Glória ao Pai, ao Filho e ao Espírito Santo, como era no princípio, agora e sempre. Amém."
          }
        }
      }
    },
    "prayers.gloriaPatri.name" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Glory Be"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gloria al Padre"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Glória ao Pai"
          }
        }
      }
    },
    "prayers.gloriaPatriEtFatima.name" : {
      "localizations" : {
