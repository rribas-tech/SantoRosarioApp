    "Mistério do Dia" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mystery of the Day"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mistero del Giorno"
          }
        },
        "pt-BR" : {
