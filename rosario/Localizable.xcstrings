    "mysteries.sorrowful.second.name" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The scourging at the pillar"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gesù è flagellato dai soldati"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Flagelação de Jesus"
          }
        }
      }
    },
    "mysteries.sorrowful.second.scripture" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Pilate released Barabbas to them, but after he had Jesus scourged, he handed him over to be crucified\" (Mt 27:26)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pilato rimise in libertà per loro Barabba e, dopo aver fatto flagellare Gesù, lo consegnò perché fosse crocifisso. (Mt 27,26)"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Então lhes soltou Barrabás; mas a Jesus mandou açoitar, e o entregou para ser crucificado» (Mt 27,26)."
          }
        }
      }
    },
    "mysteries.sorrowful.second.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Second Sorrowful Mystery"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Secondo mistero del dolore"
          }
        },
        "pt-BR" : {
