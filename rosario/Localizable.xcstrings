          }
        }
      }
    },
    "prayers.jaculatoriaFatima.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "sem tradução"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "sem tradução"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Óh! Meu Jesus, perdoai-nos, livrai-nos do fogo do inferno, vai as almas todas para o Céu e socorrei principalmente as que mais precisarem."
          }
        }
      }
    },
    "prayers.jaculatoriaFatima.name" : {
      "localizations" : {
